# Compose env file - read by `docker compose` automatically.
# Generated by setup-proxy.sh on first run; do not commit (chmod 600).

# Hysteria2 listens on this UDP port (host side).
HY2_PORT=443

# Xray VLESS+Reality listens on this TCP port (host side).
REALITY_PORT=443

# Subdomain FQDN the cert is issued for. Must NOT be the apex.
DOMAIN=proxy.example.com

# Cloudflare API token, scoped to Zone:Read + DNS:Edit on the zone.
# Passed into the acme container as $CF_Token for the dns_cf plugin.
CF_TOKEN=cf-token-goes-here

# Reality target the server impersonates - must support TLS 1.3 + X25519 + h2.
# Pick one from: https://www.v2ray-agent.com/archives/1680104902581
# Format: host:port (port is almost always 443).
REALITY_DEST=www.microsoft.com:443
